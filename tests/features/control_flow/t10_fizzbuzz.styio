# fizzbuzz := (n: i32) => {
    n % 15 ?= {
        0 => { <| "FizzBuzz" }
        _ => {
            n % 3 ?= {
                0 => { <| "Fizz" }
                _ => {
                    n % 5 ?= {
                        0 => { <| "Buzz" }
                        _ => { <| n }
                    }
                }
            }
        }
    }
}
[1, 2, 3, 4, 5] >> #(i) => {
    >_(fizzbuzz(i))
}

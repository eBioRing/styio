values <- @stdin: list[i32]

answer = -1

values.length ?= {
    0 => {
        /* empty */
    }

    1 => {
        answer = values[0]
    }

    _ => {
        answer = values[0]

        n = values.length
        [1..n-1] >> #(i) => {
            ?(values[i] > answer) => {
                answer = values[i]
            }
        }
    }
}

>_(answer)
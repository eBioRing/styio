// RUN: %{styio} --styio-ast --file %s | FileCheck %s

name := "Styio"

>_($"Hello, {name}!")

/*
  CHECK:      Binding (Final) {
  CHECK-NEXT: || Var: id { name }
  CHECK-NEXT: || Val: String { "Styio" }}
  CHECK-NEXT: Print {
  CHECK-NEXT: || FmtStr {
  CHECK-NEXT: |--| "Hello, "
  CHECK-NEXT: |--| "!"
  CHECK-NEXT: |--| id { name }}}
*/